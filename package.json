{
  "name": "ymaps-satellites ",
  "version": "0.0.0",
  "homepage": "https://novakand.github.io/ymaps-satellites/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --base-href / --serve-path /",
    "build": "ng build",
    "build:gh": "ng build --configuration=production --base-href=/ymaps-satellites/",
    "deploy": "npm run build:gh && npx ngh --dir=dist/ymaps-satellites",
    "watch": "ng build --watch --configuration development",
    "fetch:polygons": "ts-node -P tsconfig.scripts.json scripts/fetch-polygons.ts",
    "build:index": "ts-node -P tsconfig.scripts.json scripts/build-index.ts",
    "fetch:all": "npm run fetch:polygons && npm run build:index",
    "dump:routes": "ts-node -P tsconfig.scripts.json scripts/dump-routes.ts",
    "dump:localities": "ts-node -P tsconfig.scripts.json scripts/dump-localities.ts",
    "localities:xlsx": "ts-node -P tsconfig.scripts.json scripts/localities-to-xlsx.ts",
    "routes:from:xlsx": "ts-node -P tsconfig.scripts.json scripts/xlsx-to-routes.ts",
    "geocode:addresses": "ts-node -P tsconfig.scripts.json scripts/geocode-addresses-from-excel.ts",
    "routes:build": "npm run routes:from:xlsx && npm run dump:routes",
    "routes:merge": "ts-node -P tsconfig.scripts.json scripts/merge-excel.ts",
    "enrich:cities": "ts-node -P tsconfig.scripts.json scripts/enrich-cities-with-bbox.ts",
    "make:retry-list": "ts-node -P tsconfig.scripts.json scripts/make-retry-list.ts",
    "merge:routes": "ts-node -P tsconfig.scripts.json scripts/merge-route-lists.ts",
    "make:routes-list": "ts-node -P tsconfig.scripts.json scripts/make-routes-list.ts",
    "geocode:cities": "ts-node -P tsconfig.scripts.json scripts/geocode-random-points-by-cities.ts",
    "geocode:city-centers": "ts-node -P tsconfig.scripts.json scripts/geocode-city-centers.ts",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.24",
    "@angular/common": "^20.3.24",
    "@angular/compiler": "^20.3.24",
    "@angular/core": "^20.3.24",
    "@angular/forms": "^20.3.24",
    "@angular/platform-browser": "^20.3.24",
    "@angular/platform-browser-dynamic": "^20.3.24",
    "@angular/router": "^20.3.24",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "@primeng/themes": "^20.1.1",
    "@primeuix/themes": "^1.2.3",
    "@turf/helpers": "^7.2.0",
    "@turf/turf": "^7.2.0",
    "@yandex/ymaps3-clusterer": "^0.0.10",
    "angular-yandex-maps-v3": "^20.1.0",
    "csv-parse": "^6.1.0",
    "geomagnetism": "^0.2.0",
    "primeicons": "^7.0.0",
    "primelocale": "^2.1.2",
    "primeng": "^20.1.1",
    "rbush": "^4.0.1",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.27",
    "@angular/cli": "^20.3.27",
    "@angular/compiler-cli": "^20.3.24",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/geojson": "^7946.0.16",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^24.3.0",
    "@yandex/ymaps3-types": "^1.0.17179206",
    "angular-cli-ghpages": "^2.0.3",
    "autoprefixer": "^10.4.21",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.3",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.1.8",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  }
}
